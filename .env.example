# Copy this file to .env and fill in your values for local testing.
# This file must NOT be committed.

# ── Storage (one of the two is required) ──────────────────────────────────────

# Name of the GCS bucket that stores GPX files and metadata.json
GCS_BUCKET_NAME=your-gcs-bucket-name

# Local output directory — use this instead of GCS_BUCKET_NAME for offline development.
# When set, all files are written to disk; no GCP credentials are needed.
# LOCAL_OUTPUT_DIR=./output

# ── Optional overrides ────────────────────────────────────────────────────────

# (Optional) Override the base URL for GPX downloads
# GPX_BASE_URL=https://turistaterkepek.hu/kekturahu/gpx/nagyszakasz
